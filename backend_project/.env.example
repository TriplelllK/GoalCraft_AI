# ── GoalCraft AI — Environment Configuration ──────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Application ──────────────────────────────────────────────────
APP_TITLE=GoalCraft AI
APP_VERSION=1.0.0
CORS_ORIGINS=*

# ── Storage Backend ──────────────────────────────────────────────
# Options: "memory" (demo, no external deps) or "postgres" (production)
STORAGE_BACKEND=memory

# ── PostgreSQL (only needed if STORAGE_BACKEND=postgres) ─────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hr_goal_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_AUTO_INIT=true

# ── Vector Store Backend ─────────────────────────────────────────
# Options: "memory" (demo, TF-IDF-like) or "qdrant" (production)
VECTOR_BACKEND=memory

# ── Qdrant (only needed if VECTOR_BACKEND=qdrant) ───────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
VECTOR_COLLECTION=hr_goals
VECTOR_SIZE=256

# ── LLM / OpenAI (optional) ─────────────────────────────────────
# When set: generation, rewriting and OKR mapping use GPT-4o-mini
# When empty: graceful degradation to rule-based templates
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
